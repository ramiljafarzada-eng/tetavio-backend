DATABASE_URL="postgresql://postgres:postgres@localhost:5432/logistics_app?schema=public"

PORT=3000
NODE_ENV=development
JWT_ACCESS_SECRET="replace-with-secure-value"
JWT_REFRESH_SECRET="replace-with-secure-value"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

APP_BASE_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:5173,http://localhost:5175,http://localhost:3000"
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
PASHA_WEBHOOK_SECRET="replace-with-pasha-webhook-secret"
PAYMENT_GATEWAY="MOCK"
FRONTEND_PRODUCTION_URL="http://localhost:5173"
PASHA_MERCHANT_HANDLER_URL="https://ecomm.pashabank.az:18443/ecomm2/MerchantHandler"
PASHA_CLIENT_HANDLER_URL="https://ecomm.pashabank.az:8463/ecomm2/ClientHandler"
PASHA_TERMINAL_ID="replace-with-terminal-id"
PASHA_PFX_PATH=""
PASHA_CERT_PATH=""
PASHA_KEY_PATH=""
PASHA_CA_PATH=""
PASHA_KEY_PASSPHRASE=""
PASHA_REJECT_UNAUTHORIZED="true"
