generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  INDIVIDUAL
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
  SUPER_ADMIN
}

enum PlanInterval {
  NONE
  MONTH
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

enum OrderType {
  UPGRADE
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum BankTransactionType {
  INFLOW
  OUTFLOW
}

enum PaymentGateway {
  MOCK
  PASHA
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
}

enum WebhookProcessingStatus {
  PENDING
  PROCESSED
  FAILED
}

enum SupportThreadStatus {
  OPEN
  WAITING_SUPPORT
  WAITING_ACCOUNT
  CLOSED
}

enum SupportThreadPriority {
  NORMAL
  URGENT
}

enum SupportThreadCategory {
  TECHNICAL
  BILLING
  AUTH
  REPORTING
  OTHER
}

enum SupportAuthorType {
  ACCOUNT_USER
  SUPER_ADMIN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  MANAGER_APPROVED
  HR_APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum PayrollItemType {
  EARNING
  DEDUCTION
}

model Account {
  id                 String          @id @default(uuid()) @db.Uuid
  name               String
  type               AccountType     @default(INDIVIDUAL)
  users              User[]
  subscriptions      Subscription[]
  orders             Order[]
  companyProfile     CompanyProfile?
  customers          Customer[]
  vendors            Vendor[]
  invoices           Invoice[]
  invoicePayments    InvoicePayment[]
  demoActivatedAt    DateTime?       @map("demo_activated_at") @db.Timestamptz(6)
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  adminNotes         AdminAccountNote[]
  adminFlags         AdminAccountFlag[]
  anomalyReviews     AdminAnomalyReview[]
  accountingAccounts AccountingAccount[]
  journalEntries     JournalEntry[]
  bills              Bill[]
  bankAccounts       BankAccount[]
  bankTransactions   BankTransaction[]
  supportThreads     SupportThread[]
  employees          Employee[]
  departments        Department[]
  positions          Position[]
  workSchedules      WorkSchedule[]
  attendanceLogs     AttendanceLog[]
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  payrolls           Payroll[]

  @@map("accounts")
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  accountId               String                   @map("account_id") @db.Uuid
  account                 Account                  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  email                   String                   @unique
  passwordHash            String                   @map("password_hash")
  fullName                String?                  @map("full_name")
  isEmailVerified         Boolean                  @default(false) @map("is_email_verified")
  role                    UserRole                 @default(OWNER)
  status                  UserStatus               @default(ACTIVE)
  lastLoginAt             DateTime?                @map("last_login_at") @db.Timestamptz(6)
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  adminNotes              AdminAccountNote[]        @relation("AdminNoteAuthor")
  createdFlags            AdminAccountFlag[]        @relation("AdminFlagCreator")
  clearedFlags            AdminAccountFlag[]        @relation("AdminFlagClearer")
  anomalyReviews          AdminAnomalyReview[]      @relation("AdminAnomalyReviewer")
  adminAuditLogs          AdminAuditLog[]           @relation("AdminAuditActor")
  supportThreadsCreated   SupportThread[]           @relation("SupportThreadCreator")
  supportMessages         SupportMessage[]          @relation("SupportMessageAuthor")
  employee                Employee?

  @@index([accountId])
  @@map("users")
}

model RefreshToken {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String        @unique @map("token_hash")
  familyId          String        @map("family_id") @db.Uuid
  replacedByTokenId String?       @unique @map("replaced_by_token_id") @db.Uuid
  replacedByToken   RefreshToken? @relation("RefreshTokenReplacement", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replacedToken     RefreshToken? @relation("RefreshTokenReplacement")
  revokedAt         DateTime?     @map("revoked_at") @db.Timestamptz(6)
  expiresAt         DateTime      @map("expires_at") @db.Timestamptz(6)
  ip                String?
  userAgent         String?       @map("user_agent")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Plan {
  id                      String         @id @default(uuid()) @db.Uuid
  code                    String         @unique
  name                    String
  priceMinor              Int            @default(0) @map("price_minor")
  currency                String         @default("AZN") @db.Char(3)
  interval                PlanInterval
  isActive                Boolean        @default(true) @map("is_active")
  sortOrder               Int            @default(0) @map("sort_order")
  subscriptions           Subscription[] @relation("SubscriptionPlan")
  scheduledSubscriptions  Subscription[] @relation("ScheduledSubscriptionPlan")
  targetOrders            Order[]
  createdAt               DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("plans")
}

model Subscription {
  id                String             @id @default(uuid()) @db.Uuid
  accountId         String             @map("account_id") @db.Uuid
  account           Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  planId            String             @map("plan_id") @db.Uuid
  plan              Plan               @relation("SubscriptionPlan", fields: [planId], references: [id])
  status            SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime?         @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd  DateTime?          @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd Boolean            @default(false) @map("cancel_at_period_end")
  scheduledPlanId   String?            @map("scheduled_plan_id") @db.Uuid
  scheduledPlan     Plan?              @relation("ScheduledSubscriptionPlan", fields: [scheduledPlanId], references: [id])
  scheduledChangeAt DateTime?          @map("scheduled_change_at") @db.Timestamptz(6)
  orders            Order[]
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([accountId])
  @@index([planId])
  @@index([scheduledPlanId])
  @@map("subscriptions")
}

model Order {
  id             String               @id @default(uuid()) @db.Uuid
  accountId      String               @map("account_id") @db.Uuid
  account        Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subscriptionId String?              @map("subscription_id") @db.Uuid
  subscription   Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  targetPlanId   String               @map("target_plan_id") @db.Uuid
  targetPlan     Plan                 @relation(fields: [targetPlanId], references: [id])
  type           OrderType            @default(UPGRADE)
  status         OrderStatus          @default(PENDING)
  amountMinor    Int                  @map("amount_minor")
  currency       String               @default("AZN") @db.Char(3)
  idempotencyKey String               @unique @map("idempotency_key")
  paidAt         DateTime?            @map("paid_at") @db.Timestamptz(6)
  payments       PaymentTransaction[]
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([accountId])
  @@index([subscriptionId])
  @@index([targetPlanId])
  @@map("orders")
}

model PaymentTransaction {
  id              String        @id @default(uuid()) @db.Uuid
  orderId         String        @map("order_id") @db.Uuid
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gateway         PaymentGateway
  gatewayPaymentId String?      @map("gateway_payment_id")
  status          PaymentStatus @default(INITIATED)
  amountMinor     Int           @map("amount_minor")
  currency        String        @default("AZN") @db.Char(3)
  requestPayload  Json?         @map("request_payload")
  responsePayload Json?         @map("response_payload")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([orderId])
  @@index([gatewayPaymentId])
  @@map("payment_transactions")
}

model PaymentWebhookEvent {
  id               String                  @id @default(uuid()) @db.Uuid
  gateway          PaymentGateway
  eventId          String                  @map("event_id")
  eventType        String                  @map("event_type")
  signatureValid   Boolean                 @default(false) @map("signature_valid")
  payload          Json
  processedAt      DateTime?               @map("processed_at") @db.Timestamptz(6)
  processingStatus WebhookProcessingStatus @default(PENDING) @map("processing_status")
  errorMessage     String?                 @map("error_message")
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([gateway, eventId])
  @@map("payment_webhook_events")
}

model CompanyProfile {
  id                   String   @id @default(uuid()) @db.Uuid
  accountId            String   @unique @map("account_id") @db.Uuid
  account              Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  companyName          String   @map("company_name")
  taxId                String?  @map("tax_id")
  mobilePhone          String?  @map("mobile_phone")
  entityType           String   @default("Huquqi sexs") @map("entity_type")
  currency             String   @default("AZN") @db.Char(3)
  fiscalYear           String?  @map("fiscal_year")
  invoicePrefix        String?  @map("invoice_prefix")
  quotePrefix          String?  @map("quote_prefix")
  defaultPaymentTerm   String?  @map("default_payment_term")
  defaultTaxLabel      String?  @map("default_tax_label")
  numberingMode        String?  @map("numbering_mode")
  stockWarning         String?  @map("stock_warning")
  negativeStock        String?  @map("negative_stock")
  discountMode         String?  @map("discount_mode")
  discountTiming       String?  @map("discount_timing")
  additionalAdjustment String?  @map("additional_adjustment")
  shippingCharge       String?  @map("shipping_charge")
  taxMode              String?  @map("tax_mode")
  salesRoundingMode    String?  @map("sales_rounding_mode")
  salespersonField     String?  @map("salesperson_field")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("company_profiles")
}

model Customer {
  id             String    @id @default(uuid()) @db.Uuid
  accountId      String    @map("account_id") @db.Uuid
  account        Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  displayName    String    @map("display_name")
  companyName    String?   @map("company_name")
  email          String?
  phone          String?
  taxId          String?   @map("tax_id")
  status         String    @default("ACTIVE")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  invoices       Invoice[]

  @@index([accountId])
  @@index([accountId, displayName])
  @@map("customers")
}

model Vendor {
  id             String    @id @default(uuid()) @db.Uuid
  accountId      String    @map("account_id") @db.Uuid
  account        Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  vendorName     String    @map("vendor_name")
  companyName    String?   @map("company_name")
  email          String?
  phone          String?
  taxId          String?   @map("tax_id")
  status         String    @default("ACTIVE")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  bills          Bill[]

  @@index([accountId])
  @@index([accountId, vendorName])
  @@map("vendors")
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  accountId      String        @map("account_id") @db.Uuid
  account        Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  customerId     String        @map("customer_id") @db.Uuid
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoiceNumber  String        @map("invoice_number")
  status         String        @default("DRAFT")
  issueDate      DateTime      @map("issue_date") @db.Date
  dueDate        DateTime?     @map("due_date") @db.Date
  currency       String        @default("AZN") @db.Char(3)
  subTotalMinor  Int           @default(0) @map("sub_total_minor")
  taxMinor       Int           @default(0) @map("tax_minor")
  discountMinor  Int           @default(0) @map("discount_minor")
  totalMinor     Int           @default(0) @map("total_minor")
  notes          String?
  paidAt         DateTime?     @map("paid_at") @db.Timestamptz(6)
  deletedAt      DateTime?     @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  lines          InvoiceLine[]
  payments       InvoicePayment[]

  @@index([accountId])
  @@index([customerId])
  @@unique([accountId, invoiceNumber])
  @@map("invoices")
}

model InvoiceLine {
  id             String   @id @default(uuid()) @db.Uuid
  invoiceId      String   @map("invoice_id") @db.Uuid
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  itemName       String   @map("item_name")
  description    String?
  quantity       Decimal  @default(1) @db.Decimal(18, 4)
  unitPriceMinor Int      @default(0) @map("unit_price_minor")
  taxCode        String?  @map("tax_code")
  taxRate        Decimal? @map("tax_rate") @db.Decimal(6, 2)
  lineTotalMinor Int      @default(0) @map("line_total_minor")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([invoiceId])
  @@map("invoice_lines")
}

model InvoicePayment {
  id          String    @id @default(uuid()) @db.Uuid
  accountId   String    @map("account_id") @db.Uuid
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invoiceId   String    @map("invoice_id") @db.Uuid
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amountMinor Int       @map("amount_minor")
  paymentDate DateTime  @map("payment_date") @db.Date
  method      String?
  reference   String?
  note        String?
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([accountId])
  @@index([invoiceId])
  @@map("invoice_payments")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  accountId   String   @map("account_id") @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([accountId])
  @@index([accountId, entityType])
  @@index([actorUserId])
  @@map("audit_logs")
}

model AdminAccountNote {
  id           String   @id @default(uuid()) @db.Uuid
  accountId    String   @map("account_id") @db.Uuid
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  authorUserId String   @map("author_user_id") @db.Uuid
  author       User     @relation("AdminNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)
  note         String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([accountId])
  @@map("admin_account_notes")
}

model AdminAccountFlag {
  id              String    @id @default(uuid()) @db.Uuid
  accountId       String    @map("account_id") @db.Uuid
  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reason          String
  isActive        Boolean   @default(true) @map("is_active")
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  createdBy       User      @relation("AdminFlagCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  clearedByUserId String?   @map("cleared_by_user_id") @db.Uuid
  clearedBy       User?     @relation("AdminFlagClearer", fields: [clearedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  clearedAt       DateTime? @map("cleared_at") @db.Timestamptz(6)

  @@index([accountId])
  @@map("admin_account_flags")
}

model AdminAnomalyReview {
  id               String   @id @default(uuid()) @db.Uuid
  accountId        String   @map("account_id") @db.Uuid
  account          Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  anomalyType      String   @map("anomaly_type")
  reviewedByUserId String   @map("reviewed_by_user_id") @db.Uuid
  reviewedBy       User     @relation("AdminAnomalyReviewer", fields: [reviewedByUserId], references: [id], onDelete: Restrict)
  reviewedAt       DateTime @default(now()) @map("reviewed_at") @db.Timestamptz(6)
  note             String?

  @@unique([accountId, anomalyType])
  @@index([accountId])
  @@map("admin_anomaly_reviews")
}

model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  actor       User     @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  action      String
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([actorUserId])
  @@index([targetId])
  @@map("admin_audit_logs")
}

model AccountingAccount {
  id           String             @id @default(uuid()) @db.Uuid
  accountId    String             @map("account_id") @db.Uuid
  account      Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  code         String
  name         String
  type         String             @default("Aktiv")
  parentId     String?            @map("parent_id") @db.Uuid
  isActive     Boolean            @default(true) @map("is_active")
  balanceMinor Int                @default(0) @map("balance_minor")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?          @map("deleted_at") @db.Timestamptz(6)
  journalLines JournalEntryLine[]

  @@index([accountId])
  @@index([accountId, code])
  @@map("accounting_accounts")
}

model JournalEntry {
  id            String             @id @default(uuid()) @db.Uuid
  accountId     String             @map("account_id") @db.Uuid
  account       Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  journalNumber String             @map("journal_number")
  reference     String?
  entryDate     DateTime           @map("entry_date") @db.Date
  sourceType    String?            @map("source_type")
  sourceId      String?            @map("source_id")
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?          @map("deleted_at") @db.Timestamptz(6)
  lines         JournalEntryLine[]

  @@index([accountId])
  @@index([accountId, entryDate])
  @@map("journal_entries")
}

model JournalEntryLine {
  id                  String            @id @default(uuid()) @db.Uuid
  journalEntryId      String            @map("journal_entry_id") @db.Uuid
  journalEntry        JournalEntry      @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountingAccountId String            @map("accounting_account_id") @db.Uuid
  accountingAccount   AccountingAccount @relation(fields: [accountingAccountId], references: [id], onDelete: Restrict)
  description         String?
  debitMinor          Int               @default(0) @map("debit_minor")
  creditMinor         Int               @default(0) @map("credit_minor")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([journalEntryId])
  @@index([accountingAccountId])
  @@map("journal_entry_lines")
}

model Bill {
  id          String     @id @default(uuid()) @db.Uuid
  accountId   String     @map("account_id") @db.Uuid
  account     Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  vendorId    String     @map("vendor_id") @db.Uuid
  vendor      Vendor     @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  billNumber  String     @map("bill_number")
  status      String     @default("DRAFT")
  issueDate   DateTime   @map("issue_date") @db.Date
  dueDate     DateTime?  @map("due_date") @db.Date
  currency    String     @default("AZN") @db.Char(3)
  totalMinor  Int        @default(0) @map("total_minor")
  notes       String?
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  lines       BillLine[]

  @@index([accountId])
  @@index([vendorId])
  @@unique([accountId, billNumber])
  @@map("bills")
}

model BillLine {
  id             String    @id @default(uuid()) @db.Uuid
  billId         String    @map("bill_id") @db.Uuid
  bill           Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  itemName       String    @map("item_name")
  description    String?
  quantity       Decimal   @default(1) @db.Decimal(18, 4)
  unitPriceMinor Int       @default(0) @map("unit_price_minor")
  lineTotalMinor Int       @default(0) @map("line_total_minor")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([billId])
  @@map("bill_lines")
}

model BankAccount {
  id            String            @id @default(uuid()) @db.Uuid
  accountId     String            @map("account_id") @db.Uuid
  account       Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name          String
  currency      String            @default("AZN") @db.Char(3)
  balanceMinor  Int               @default(0) @map("balance_minor")
  deletedAt     DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  transactions  BankTransaction[]

  @@index([accountId])
  @@map("bank_accounts")
}

model BankTransaction {
  id              String              @id @default(uuid()) @db.Uuid
  accountId       String              @map("account_id") @db.Uuid
  account         Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  bankAccountId   String              @map("bank_account_id") @db.Uuid
  bankAccount     BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  type            BankTransactionType
  amountMinor     Int                 @map("amount_minor")
  description     String?
  reference       String?
  transactionDate DateTime            @map("transaction_date") @db.Date
  deletedAt       DateTime?           @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([accountId])
  @@index([bankAccountId])
  @@map("bank_transactions")
}

model SupportThread {
  id              String                @id @default(uuid()) @db.Uuid
  accountId       String                @map("account_id") @db.Uuid
  account         Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subject         String
  category        SupportThreadCategory
  priority        SupportThreadPriority @default(NORMAL)
  status          SupportThreadStatus   @default(OPEN)
  context         String?
  createdByUserId String                @map("created_by_user_id") @db.Uuid
  createdByUser   User                  @relation("SupportThreadCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  unreadForAccount Int                  @default(0) @map("unread_for_account")
  unreadForAdmin  Int                   @default(0) @map("unread_for_admin")
  lastMessageAt   DateTime              @default(now()) @map("last_message_at") @db.Timestamptz(6)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  messages        SupportMessage[]

  @@index([accountId])
  @@index([accountId, status])
  @@index([lastMessageAt])
  @@map("support_threads")
}

model SupportMessage {
  id           String            @id @default(uuid()) @db.Uuid
  threadId      String           @map("thread_id") @db.Uuid
  thread        SupportThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorUserId  String?          @map("author_user_id") @db.Uuid
  authorUser    User?            @relation("SupportMessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorType    SupportAuthorType @map("author_type")
  body          String
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([threadId])
  @@index([threadId, createdAt])
  @@map("support_messages")
}

// ─── HRM ─────────────────────────────────────────────────────────────────────

model WorkSchedule {
  id             String     @id @default(uuid()) @db.Uuid
  accountId      String     @map("account_id") @db.Uuid
  account        Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name           String
  workStartTime  String     @map("work_start_time")
  workEndTime    String     @map("work_end_time")
  breakMinutes   Int        @default(60) @map("break_minutes")
  workDays       String     @map("work_days")
  gracePeriodMin Int        @default(10) @map("grace_period_min")
  isDefault      Boolean    @default(false) @map("is_default")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  employees      Employee[]

  @@index([accountId])
  @@map("work_schedules")
}

model Department {
  id          String       @id @default(uuid()) @db.Uuid
  accountId   String       @map("account_id") @db.Uuid
  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name        String
  code        String?
  parentId    String?      @map("parent_id") @db.Uuid
  parent      Department?  @relation("DeptHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Department[] @relation("DeptHierarchy")
  managerId   String?      @map("manager_id") @db.Uuid
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  employees   Employee[]   @relation("DeptEmployees")
  manager     Employee?    @relation("DeptManager", fields: [managerId], references: [id], onDelete: SetNull)

  @@unique([accountId, code])
  @@index([accountId])
  @@index([parentId])
  @@map("departments")
}

model Position {
  id        String     @id @default(uuid()) @db.Uuid
  accountId String     @map("account_id") @db.Uuid
  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title     String
  level     Int        @default(1)
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  employees Employee[]

  @@unique([accountId, title])
  @@index([accountId])
  @@map("positions")
}

model Employee {
  id               String         @id @default(uuid()) @db.Uuid
  accountId        String         @map("account_id") @db.Uuid
  account          Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId           String?        @unique @map("user_id") @db.Uuid
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  employeeCode     String         @map("employee_code")
  firstName        String         @map("first_name")
  lastName         String         @map("last_name")
  email            String?
  phone            String?
  dateOfBirth      DateTime?      @map("date_of_birth") @db.Date
  taxId            String?        @map("tax_id")
  ssn              String?        @map("ssn")
  idCardNumber     String?        @map("id_card_number")
  education        String?        @map("education")
  bankAccount      String?        @map("bank_account")
  departmentId     String?        @map("department_id") @db.Uuid
  department       Department?    @relation("DeptEmployees", fields: [departmentId], references: [id], onDelete: SetNull)
  positionId       String?        @map("position_id") @db.Uuid
  position         Position?      @relation(fields: [positionId], references: [id], onDelete: SetNull)
  workScheduleId   String?        @map("work_schedule_id") @db.Uuid
  workSchedule     WorkSchedule?  @relation(fields: [workScheduleId], references: [id], onDelete: SetNull)
  managerId        String?        @map("manager_id") @db.Uuid
  manager          Employee?      @relation("EmpManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates     Employee[]     @relation("EmpManager")
  employmentType   EmploymentType @default(FULL_TIME) @map("employment_type")
  status           EmployeeStatus @default(ACTIVE)
  hrmRole          String         @default("EMPLOYEE") @map("hrm_role")
  startDate        DateTime       @map("start_date") @db.Date
  endDate          DateTime?      @map("end_date") @db.Date
  baseSalaryMinor  Int            @default(0) @map("base_salary_minor")
  currency         String         @default("AZN") @db.Char(3)
  deletedAt        DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  attendanceLogs   AttendanceLog[]
  leaveRequests    LeaveRequest[]
  leaveBalances    LeaveBalance[]
  payrollItems     PayrollItem[]
  managedDepts     Department[]   @relation("DeptManager")

  @@unique([accountId, employeeCode])
  @@index([accountId])
  @@index([accountId, status])
  @@index([departmentId])
  @@index([managerId])
  @@map("employees")
}

model AttendanceLog {
  id              String           @id @default(uuid()) @db.Uuid
  accountId       String           @map("account_id") @db.Uuid
  account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  employeeId      String           @map("employee_id") @db.Uuid
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime         @db.Date
  checkIn         DateTime?        @map("check_in") @db.Timestamptz(6)
  checkOut        DateTime?        @map("check_out") @db.Timestamptz(6)
  workedMinutes   Int?             @map("worked_minutes")
  lateMinutes     Int              @default(0) @map("late_minutes")
  overtimeMinutes Int              @default(0) @map("overtime_minutes")
  status          AttendanceStatus @default(PRESENT)
  note            String?
  source          String           @default("MANUAL")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([employeeId, date])
  @@index([accountId])
  @@index([accountId, date])
  @@index([employeeId])
  @@map("attendance_logs")
}

model LeaveBalance {
  id          String    @id @default(uuid()) @db.Uuid
  accountId   String    @map("account_id") @db.Uuid
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  employeeId  String    @map("employee_id") @db.Uuid
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @map("leave_type")
  year        Int
  allocated   Int       @default(0)
  used        Int       @default(0)
  pending     Int       @default(0)
  carried     Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([employeeId, leaveType, year])
  @@index([accountId])
  @@index([employeeId])
  @@map("leave_balances")
}

model LeaveRequest {
  id                String      @id @default(uuid()) @db.Uuid
  accountId         String      @map("account_id") @db.Uuid
  account           Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  employeeId        String      @map("employee_id") @db.Uuid
  employee          Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType         LeaveType   @map("leave_type")
  startDate         DateTime    @map("start_date") @db.Date
  endDate           DateTime    @map("end_date") @db.Date
  daysRequested     Int         @map("days_requested")
  reason            String?
  status            LeaveStatus @default(PENDING)
  managerApprovedBy String?     @map("manager_approved_by") @db.Uuid
  managerApprovedAt DateTime?   @map("manager_approved_at") @db.Timestamptz(6)
  hrApprovedBy      String?     @map("hr_approved_by") @db.Uuid
  hrApprovedAt      DateTime?   @map("hr_approved_at") @db.Timestamptz(6)
  rejectedBy        String?     @map("rejected_by") @db.Uuid
  rejectedAt        DateTime?   @map("rejected_at") @db.Timestamptz(6)
  rejectionReason   String?     @map("rejection_reason")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([accountId])
  @@index([employeeId])
  @@index([accountId, status])
  @@map("leave_requests")
}

model Payroll {
  id                   String        @id @default(uuid()) @db.Uuid
  accountId            String        @map("account_id") @db.Uuid
  account              Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  periodStart          DateTime      @map("period_start") @db.Date
  periodEnd            DateTime      @map("period_end") @db.Date
  totalGrossMinor      Int           @default(0) @map("total_gross_minor")
  totalDeductionsMinor Int           @default(0) @map("total_deductions_minor")
  totalNetMinor        Int           @default(0) @map("total_net_minor")
  status               PayrollStatus @default(DRAFT)
  journalEntryId       String?       @unique @map("journal_entry_id") @db.Uuid
  paidAt               DateTime?     @map("paid_at") @db.Timestamptz(6)
  paymentBankAccountId String?       @map("payment_bank_account_id") @db.Uuid
  createdBy            String        @map("created_by") @db.Uuid
  approvedBy           String?       @map("approved_by") @db.Uuid
  approvedAt           DateTime?     @map("approved_at") @db.Timestamptz(6)
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  items                PayrollItem[]

  @@unique([accountId, periodStart, periodEnd])
  @@index([accountId])
  @@index([accountId, status])
  @@map("payrolls")
}

model PayrollItem {
  id          String          @id @default(uuid()) @db.Uuid
  accountId   String          @map("account_id") @db.Uuid
  payrollId   String          @map("payroll_id") @db.Uuid
  payroll     Payroll         @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employeeId  String          @map("employee_id") @db.Uuid
  employee    Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  type        PayrollItemType
  label       String
  amountMinor Int             @map("amount_minor")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([payrollId])
  @@index([employeeId])
  @@index([accountId])
  @@map("payroll_items")
}
